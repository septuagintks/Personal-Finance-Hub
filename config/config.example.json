{
  "environment": "development",
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "threads": 4,
    "request_worker_threads": 8,
    "request_queue_capacity": 256,
    "request_queue_byte_capacity": 16777216,
    "maximum_request_body_bytes": 1048576,
    "auth_worker_threads": 2,
    "auth_queue_capacity": 16,
    "auth_queue_byte_capacity": 1048576,
    "auth_rate_limit_attempts": 20,
    "auth_rate_limit_window_seconds": 60,
    "auth_rate_limit_sources": 10000
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "pfh_dev",
    "user": "pfh_user",
    "password": "REPLACE_WITH_ACTUAL_PASSWORD",
    "pool_size": 10,
    "connection_timeout": 30
  },
  "background_database": {
    "host": "localhost",
    "port": 5432,
    "name": "pfh_dev",
    "user": "pfh_background",
    "password": "REPLACE_WITH_ACTUAL_BACKGROUND_PASSWORD",
    "pool_size": 2,
    "connection_timeout": 30
  },
  "jwt": {
    "secret": "REPLACE_WITH_ACTUAL_SECRET",
    "issuer": "pfh-api",
    "audience": "pfh-client",
    "access_token_expiry_seconds": 900,
    "refresh_token_expiry_seconds": 2592000,
    "clock_skew_seconds": 30
  },
  "logging": {
    "level": "debug",
    "output": "console",
    "file": "logs/pfh.log",
    "maximum_file_size_bytes": 10485760,
    "maximum_file_count": 5
  },
  "scheduler": {
    "enabled": true,
    "worker_threads": 2,
    "queue_capacity": 64,
    "outbox_publish_interval_seconds": 5,
    "outbox_batch_size": 100,
    "outbox_processing_timeout_seconds": 300,
    "exchange_rate_refresh_interval_minutes": 60,
    "session_cleanup_interval_minutes": 1440,
    "session_cleanup_batch_size": 1000,
    "outbox_retention_interval_minutes": 1440,
    "published_outbox_retention_days": 30,
    "outbox_retention_batch_size": 1000,
    "job_execution_timeout_seconds": 30,
    "job_lease_duration_seconds": 120
  },
  "exchange_rate": {
    "provider": "freecurrencyapi",
    "api_key": "REPLACE_WITH_ACTUAL_API_KEY",
    "request_timeout_seconds": 10
  }
}
