# Personal Finance Hub (PFH) - Environment Variables Template
# Copy to .env.local and fill in actual values.
# NEVER commit .env.local or any file containing secrets to Git.

# Database
PFH_DB_HOST=localhost
PFH_DB_PORT=5432
PFH_DB_NAME=pfh_dev
PFH_DB_USER=pfh_user
PFH_DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# JWT Authentication
PFH_JWT_SECRET=REPLACE_WITH_256BIT_RANDOM_SECRET
PFH_JWT_ACCESS_EXPIRY_SECONDS=900
PFH_JWT_REFRESH_EXPIRY_SECONDS=2592000

# Password hashing pepper (optional; do not rotate without user migration plan)
PFH_PASSWORD_PEPPER=REPLACE_WITH_PEPPER_OR_LEAVE_EMPTY

# Logging
PFH_LOG_LEVEL=debug
PFH_LOG_OUTPUT=console
PFH_LOG_FILE=logs/pfh.log

# Exchange rate provider
PFH_EXCHANGE_RATE_PROVIDER=mock
PFH_EXCHANGE_RATE_API_KEY=REPLACE_WITH_ACTUAL_API_KEY

# Server
PFH_SERVER_HOST=0.0.0.0
PFH_SERVER_PORT=8080
PFH_SERVER_THREADS=4

# Flyway (for manual CLI migration)
FLYWAY_PASSWORD=${PFH_DB_PASSWORD}
