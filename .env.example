# Personal Finance Hub (PFH) - Environment Variables Template
# Copy to .env.local and fill in actual values.
# NEVER commit .env.local or any file containing secrets to Git.

# Runtime
PFH_ENVIRONMENT=development

# Request-serving database (ordinary role, FORCE RLS applies)
PFH_DB_HOST=localhost
PFH_DB_PORT=5432
PFH_DB_NAME=pfh_dev
PFH_DB_USER=pfh_user
PFH_DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Background read-only database (distinct BYPASSRLS role)
PFH_BACKGROUND_DB_HOST=localhost
PFH_BACKGROUND_DB_PORT=5432
PFH_BACKGROUND_DB_NAME=pfh_dev
PFH_BACKGROUND_DB_USER=pfh_background_reader
PFH_BACKGROUND_DB_PASSWORD=REPLACE_WITH_DISTINCT_SECURE_PASSWORD

# JWT Authentication
PFH_JWT_SECRET=REPLACE_WITH_256BIT_RANDOM_SECRET

# Password hashing pepper (optional; leave empty or set a real secret)
# Do not rotate a configured pepper without a user migration plan.
PFH_PASSWORD_PEPPER=

# FreeCurrencyAPI primary-provider secret (exchangerate.fun fallback needs none)
PFH_FREECURRENCYAPI_API_KEY=REPLACE_WITH_ACTUAL_API_KEY

# Server, logging, JWT expiry, pool sizes, and provider selection currently
# remain JSON-configured. Do not add environment names here until the loader
# implements and tests their overlay behavior.

# Flyway (for manual CLI migration)
FLYWAY_PASSWORD=${PFH_DB_PASSWORD}
