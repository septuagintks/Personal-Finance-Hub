{
  "name": "@pfh/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "api:generate": "openapi-typescript ../Docs/Architecture/10_REST_API_OpenAPI.json -o src/generated/api-types.ts",
    "api:check": "openapi-typescript ../Docs/Architecture/10_REST_API_OpenAPI.json -o src/generated/api-types.ts && git diff --exit-code -- src/generated/api-types.ts",
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "vue-tsc --noEmit && vite build",
    "bundle:check": "node tools/validate-bundle.mjs",
    "dependency:check": "node tools/validate-dependencies.mjs",
    "security:check": "node tools/validate-release-security.mjs",
    "i18n:check": "node tools/validate-i18n.mjs",
    "release:check": "corepack pnpm bundle:check && corepack pnpm dependency:check && corepack pnpm security:check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "quality": "corepack pnpm api:check && corepack pnpm i18n:check && corepack pnpm lint && corepack pnpm format:check && corepack pnpm test && corepack pnpm build && corepack pnpm release:check"
  },
  "dependencies": {
    "@js-temporal/polyfill": "0.5.1",
    "@lucide/vue": "1.24.0",
    "axios": "1.16.0",
    "decimal.js": "10.5.0",
    "echarts": "6.1.0",
    "pinia": "3.0.3",
    "vue": "3.5.13",
    "vue-i18n": "11.4.7",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-basic-ssl": "1.2.0",
    "@vitejs/plugin-vue": "5.2.3",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "26.0.0",
    "msw": "2.15.0",
    "openapi-typescript": "7.8.0",
    "prettier": "3.9.5",
    "typescript": "5.8.2",
    "typescript-eslint": "8.64.0",
    "vite": "6.2.5",
    "vitest": "3.1.1",
    "vue-tsc": "2.2.8"
  }
}
